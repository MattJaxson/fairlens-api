# Project Libra Configuration

# Application
APP_NAME=Project Libra
API_VERSION=v1

# Database
DATABASE_URL=sqlite+aiosqlite:///./fairlens.db

# Redis (for rate limiting and caching)
REDIS_URL=redis://localhost:6379/0

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PRO=price_pro_monthly_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_monthly_id

# Anthropic (for Claude-powered advanced analysis)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Security
SECRET_KEY=your-secret-key-change-in-production
